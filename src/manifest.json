{
  "manifest_version": 3,
  "name": "Smart Video Speed Controller",
  "short_name": "Video Speed",
  "version": "1.3.0",
  "description": "Automatically remember and apply different video playback speeds for every unique URL or website. Supports global defaults & shortcuts.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Smart Video Speed Controller",
    "default_popup": "popup.html"
  },
  "commands": {
    "speed-up": {
      "suggested_key": {
        "default": "Alt+Period"
      },
      "description": "加速 +0.1x"
    },
    "speed-down": {
      "suggested_key": {
        "default": "Alt+Comma"
      },
      "description": "减速 −0.1x"
    },
    "reset-speed": {
      "suggested_key": {
        "default": "Alt+0"
      },
      "description": "重置为默认速度"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
